<% layout("layout/boilerplate") %>

<section class="menu-page page-transition">
  <h2 class="menu-title">
  ----- <span class="menu-text">MENU</span> -----
  </h2>


  <div class="category-grid">
    <% for (let category of categories) { %>
      <a href="/menu/<%= category.slug %>?table=<%= tableNumber %>" class="category-card">

        <div class="category-name">
          <%= category.name %>
        </div>

        <div class="category-image-wrapper">
          <img loading="lazy"
            src="<%= category.menuImage %>"
            alt="<%= category.name %>"
          />
        </div>

      </a>
    <% } %>
  </div>
</section>

