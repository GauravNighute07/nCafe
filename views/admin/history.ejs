<% layout("layout/admin") %>

<section class="history-page">

  <h2 class="history-title">Order History</h2>

  <div class="history-filters">

    <a href="/admin/history?filter=today"
       class="filter-btn <%= activeFilter === 'today' ? 'active' : '' %>">
       Today
    </a>

    <a href="/admin/history?filter=week"
       class="filter-btn <%= activeFilter === 'week' ? 'active' : '' %>">
       Week
    </a>

    <a href="/admin/history?filter=month"
       class="filter-btn <%= activeFilter === 'month' ? 'active' : '' %>">
       Month
    </a>

  </div>

  <div class="history-list">

    <% if (orders.length === 0) { %>
      <p class="no-orders">No Orders Found</p>
    <% } %>

    <% orders.forEach(order => { %>

      <div class="history-row">

        <div class="history-main">

          <span class="table-label">Table <%= order.tableNumber %></span>

          <span class="time-label">
            <%= order.createdAt.toLocaleTimeString() %>
          </span>

          <span class="amount-label">
            ₹ <%= order.totalAmount %>
          </span>

          <button class="details-btn">View</button>

        </div>

        <div class="history-details">

          <% order.items.forEach(item => { %>
            <div class="details-item">
              <span>
                <%= item.name %> × <%= item.quantity %>
              </span>

              <span>
                ₹ <%= item.price * item.quantity %>
              </span>
            </div>
          <% }) %>

        </div>

      </div>

    <% }) %>

  </div>

  <div class="history-summary">
    <span>
        Total Orders : <span class="summary-value"><%= totalOrders %></span>
    </span>

    <span>
        Total Revenue : ₹ <span class="summary-value"><%= totalRevenue %></span>
    </span>
   </div>

</section>

<script>
  document.querySelectorAll(".details-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const details = btn.closest(".history-row")
                         .querySelector(".history-details");

      details.classList.toggle("show");
    });
  });
</script>
